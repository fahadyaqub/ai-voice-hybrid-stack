# --- Required secrets ---
POSTGRES_PASSWORD=change-me-postgres
LITELLM_MASTER_KEY=sk-change-me-master-key

# --- Online-first provider keys ---
GEMINI_API_KEY=
DEEPSEEK_API_KEY=
OPENAI_API_KEY=

# Optional for future use
ANTHROPIC_API_KEY=

# --- n8n ---
N8N_HOST=localhost
N8N_PROTOCOL=http
N8N_SECURE_COOKIE=false
N8N_ENCRYPTION_KEY=change-me-n8n-encryption-key
N8N_BASIC_AUTH_USER=admin
N8N_BASIC_AUTH_PASSWORD=change-me-n8n-password

# --- Cache ---
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=
LITELLM_CACHE_TTL=1800
SKIP_ONLINE_KEY_CHECK=false

# --- Low-memory safety guards (Ollama) ---
OLLAMA_NUM_PARALLEL=1
OLLAMA_MAX_LOADED_MODELS=1
OLLAMA_KEEP_ALIVE=0

# Local fallback model pull set (small only for online-first mode)
OLLAMA_PULL_MODELS=qwen2.5:3b-instruct llama3.2:3b

# --- OpenClaw ---
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.2.26
OPENCLAW_GATEWAY_TOKEN=change-me-openclaw-gateway-token
